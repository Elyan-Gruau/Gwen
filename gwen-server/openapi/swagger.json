									"$ref": "#/components/schemas/HealthStatus"
								},
								"examples": {
									"Example 1": {
										"value": {
											"status": "ok",
											"uptime": 123.45,
											"environment": "development"
										}
									}
								}
							}
						}
					}
				},
				"description": "Health check endpoint",
				"tags": [
					"Status"
				],
				"security": [],
				"parameters": []
			}
		},
