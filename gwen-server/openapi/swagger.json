{
	"openapi": "3.0.0",
	"components": {
		"examples": {},
		"headers": {},
		"parameters": {},
		"requestBodies": {},
		"responses": {},
		"schemas": {
			"HealthStatus": {
				"properties": {
					"status": {
						"type": "string"
					},
					"timestamp": {
						"type": "string"
					},
					"uptime": {
						"type": "number",
						"format": "double"
					},
					"environment": {
						"type": "string"
					}
				},
				"required": [
					"status",
					"timestamp",
					"uptime",
					"environment"
				],
				"type": "object",
				"additionalProperties": false
			},
			"DTOGameStatus": {
				"type": "string",
				"enum": [
					"ACTIVE",
					"FINISHED",
					"ABANDONED"
				]
			},
			"DTOGame": {
				"properties": {
					"updated_at": {
						"type": "string"
					},
					"created_at": {
						"type": "string"
					},
					"winner_id": {
						"type": "string",
						"nullable": true
					},
					"status": {
						"$ref": "#/components/schemas/DTOGameStatus"
					},
					"player2_id": {
						"type": "string"
					},
					"player1_id": {
						"type": "string"
					},
					"_id": {
						"type": "string"
					}
				},
				"required": [
					"winner_id",
					"status",
					"player2_id",
					"player1_id",
					"_id"
				],
				"type": "object"
			},
			"DTOGamePhase": {
				"type": "string",
				"enum": [
					"WAITING_FOR_PLAYERS",
					"REDRAW",
					"FLIP_COIN",
					"PLAY_CARDS",
					"END"
				]
			},
			"Player": {
				"properties": {},
				"type": "object",
				"additionalProperties": false
			},
			"PlayerRows": {
				"properties": {},
				"type": "object",
				"additionalProperties": false
			},
			"DTOGameResult": {
				"type": "string",
				"enum": [
					"WIN",
					"LOSS",
					"DRAW"
				]
			},
			"DTORoundEndResult": {
				"properties": {
					"player2_gems": {
						"type": "number",
						"format": "double"
					},
					"player1_gems": {
						"type": "number",
						"format": "double"
					},
					"player2_score": {
						"type": "number",
						"format": "double"
					},
					"player1_score": {
						"type": "number",
						"format": "double"
					},
					"player2_result": {
						"$ref": "#/components/schemas/DTOGameResult"
					},
					"player1_result": {
						"$ref": "#/components/schemas/DTOGameResult"
					},
					"round": {
						"type": "number",
						"format": "double"
					}
				},
				"required": [
					"player2_gems",
					"player1_gems",
					"player2_score",
					"player1_score",
					"player2_result",
					"player1_result",
					"round"
				],
				"type": "object",
				"description": "Round end event: Shows overlay for ~3 seconds during game\r\nContains each player's result from their perspective"
			},
			"DTOGameEndResult": {
				"properties": {
					"player2_elo_change": {
						"type": "number",
						"format": "double"
					},
					"player1_elo_change": {
						"type": "number",
						"format": "double",
						"description": "TODO: Will be populated when Elo system is implemented"
					},
					"winner_id": {
						"type": "string"
					},
					"player2_gems_lost": {
						"type": "number",
						"format": "double"
					},
					"player1_gems_lost": {
						"type": "number",
						"format": "double"
					},
					"player2_result": {
						"$ref": "#/components/schemas/DTOGameResult"
					},
					"player1_result": {
						"$ref": "#/components/schemas/DTOGameResult"
					},
					"player2_id": {
						"type": "string"
					},
					"player1_id": {
						"type": "string"
					}
				},
				"required": [
					"winner_id",
					"player2_gems_lost",
					"player1_gems_lost",
					"player2_result",
					"player1_result",
					"player2_id",
					"player1_id"
				],
				"type": "object",
				"description": "Game end result: Shows persistent page when game is over\r\nIncludes standings and final results"
			},
			"DTOGameWithMetadata": {
				"properties": {
					"game": {
						"properties": {
							"gameEndResult": {
								"allOf": [
									{
										"$ref": "#/components/schemas/DTOGameEndResult"
									}
								],
								"nullable": true,
								"description": "Final game result (null if game not ended)"
							},
							"lastRoundResult": {
								"allOf": [
									{
										"$ref": "#/components/schemas/DTORoundEndResult"
									}
								],
								"nullable": true,
								"description": "Result of last completed round (null if no round completed)"
							},
							"player2Rows": {
								"$ref": "#/components/schemas/PlayerRows"
							},
							"player1Rows": {
								"$ref": "#/components/schemas/PlayerRows"
							},
							"player2": {
								"$ref": "#/components/schemas/Player"
							},
							"player1": {
								"$ref": "#/components/schemas/Player"
							},
							"currentPlayerTurnUserId": {
								"type": "string",
								"nullable": true
							},
							"currentRound": {
								"type": "number",
								"format": "double"
							},
							"phase": {
								"$ref": "#/components/schemas/DTOGamePhase"
							}
						},
						"required": [
							"player2Rows",
							"player1Rows",
							"player2",
							"player1",
							"currentPlayerTurnUserId",
							"currentRound",
							"phase"
						],
						"type": "object"
					},
					"metadata": {
						"$ref": "#/components/schemas/DTOGame"
					}
				},
				"required": [
					"game",
					"metadata"
				],
				"type": "object"
			},
			"DTOPlaceCardRequest": {
				"properties": {
					"rowType": {
						"type": "string",
						"enum": [
							"MELEE",
							"RANGED",
							"SIEGE"
						]
					},
					"cardId": {
						"type": "string"
					},
					"playerId": {
						"type": "string"
					}
				},
				"required": [
					"rowType",
					"cardId",
					"playerId"
				],
				"type": "object"
			},
			"DTOPassTurnRequest": {
				"properties": {
					"playerId": {
						"type": "string"
					}
				},
				"required": [
					"playerId"
				],
				"type": "object"
			},
			"DTOFinishGameRequest": {
				"properties": {
					"winnerId": {
						"type": "string"
					}
				},
				"required": [
					"winnerId"
				],
				"type": "object"
			},
			"DTOUserFactionDeck": {
				"properties": {
					"_id": {
						"type": "string"
					},
					"user_id": {
						"type": "string"
					},
					"faction_id": {
						"type": "string"
					},
					"leader_card_id": {
						"type": "string",
						"nullable": true
					},
					"unit_card_ids": {
						"items": {
							"type": "string"
						},
						"type": "array"
					},
					"special_card_ids": {
						"items": {
							"type": "string"
						},
						"type": "array"
					},
					"created_at": {
						"type": "string"
					},
					"updated_at": {
						"type": "string"
					}
				},
				"required": [
					"user_id",
					"faction_id",
					"leader_card_id",
					"unit_card_ids",
					"special_card_ids"
				],
				"type": "object",
				"additionalProperties": false
			},
			"DTOUpdateUserFactionDeckRequest": {
				"properties": {
					"leaderCardId": {
						"type": "string",
						"nullable": true
					},
					"unitCardIds": {
						"items": {
							"type": "string"
						},
						"type": "array"
					},
					"specialCardIds": {
						"items": {
							"type": "string"
						},
						"type": "array"
					}
				},
				"type": "object",
				"additionalProperties": false
			},
			"DTOUser": {
				"properties": {
					"id": {
						"type": "string"
					},
					"username": {
						"type": "string"
					},
					"email": {
						"type": "string"
					},
					"bio": {
						"type": "string"
					},
					"profilePictureUrl": {
						"type": "string",
						"nullable": true
					},
					"elo": {
						"type": "number",
						"format": "double"
					},
					"favorite_deck": {
						"type": "string",
						"nullable": true
					}
				},
				"required": [
					"id",
					"username",
					"email",
					"bio",
					"elo"
				],
				"type": "object",
				"additionalProperties": false
			},
			"DTOLoginResponse": {
				"properties": {
					"token": {
						"type": "string"
					},
					"user": {
						"$ref": "#/components/schemas/DTOUser"
					}
				},
				"required": [
					"token",
					"user"
				],
				"type": "object",
				"additionalProperties": false
			},
			"LoginRequest": {
				"properties": {
					"password": {
						"type": "string"
					},
					"username": {
						"type": "string"
					}
				},
				"required": [
					"password",
					"username"
				],
				"type": "object"
			},
			"RegisterRequest": {
				"properties": {
					"password": {
						"type": "string"
					},
					"email": {
						"type": "string"
					},
					"username": {
						"type": "string"
					}
				},
				"required": [
					"password",
					"email",
					"username"
				],
				"type": "object"
			}
		},
		"securitySchemes": {}
	},
	"info": {
		"title": "Gwen API",
		"version": "1.0.0",
		"description": "Gwen game server API",
		"contact": {
			"name": "Gwen Team"
		}
