{
	"openapi": "3.0.0",
	"components": {
		"examples": {},
		"headers": {},
		"parameters": {},
		"requestBodies": {},
		"responses": {},
		"schemas": {
			"HealthStatus": {
				"properties": {
					"status": {
						"type": "string"
					},
					"timestamp": {
						"type": "string"
					},
					"uptime": {
						"type": "number",
						"format": "double"
					},
					"environment": {
						"type": "string"
					}
				},
				"required": [
					"status",
					"timestamp",
					"uptime",
					"environment"
				],
				"type": "object",
				"additionalProperties": false
			},
			"DTOUser": {
				"properties": {
					"_id": {
						"type": "string"
					},
					"username": {
						"type": "string"
					},
					"email": {
						"type": "string"
					},
					"bio": {
						"type": "string"
					},
					"profilePictureUrl": {
						"type": "string",
						"nullable": true
					},
					"elo": {
						"type": "number",
						"format": "double"
					}
				},
				"required": [
					"_id",
					"username",
					"email",
					"bio",
					"elo"
				],
				"type": "object",
				"additionalProperties": false
			},
			"DTOLoginResponse": {
				"properties": {
					"token": {
						"type": "string"
					},
					"user": {
						"$ref": "#/components/schemas/DTOUser"
					}
				},
				"required": [
					"token",
					"user"
				],
				"type": "object",
				"additionalProperties": false
			},
			"LoginRequest": {
				"properties": {
					"password": {
						"type": "string"
					},
					"username": {
						"type": "string"
					}
				},
				"required": [
					"password",
					"username"
				],
				"type": "object"
			},
			"RegisterRequest": {
				"properties": {
					"password": {
						"type": "string"
					},
					"email": {
						"type": "string"
					},
					"username": {
						"type": "string"
					}
				},
				"required": [
					"password",
					"email",
					"username"
				],
				"type": "object"
			}
		},
		"securitySchemes": {}
	},
	"info": {
		"title": "Gwen API",
		"version": "1.0.0",
		"description": "Gwen game server API",
		"contact": {
			"name": "Gwen Team"
		}
	},
	"paths": {
		"/status/health": {
			"get": {
				"operationId": "GetHealth",
				"responses": {
					"200": {
						"description": "Server is healthy",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/HealthStatus"
								},
								"examples": {
									"Example 1": {
										"value": {
											"status": "ok",
											"uptime": 123.45,
											"environment": "development"
										}
									}
								}
							}
						}
					}
				},
				"description": "Health check endpoint",
				"tags": [
					"Status"
				],
				"security": [],
				"parameters": []
			}
		},
		"/auth/login": {
			"post": {
				"operationId": "Login",
				"responses": {
					"200": {
						"description": "Login successful",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/DTOLoginResponse"
								}
							}
						}
					},
					"401": {
						"description": "Invalid credentials"
					}
				},
				"tags": [
					"Auth"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/LoginRequest"
							}
						}
					}
				}
			}
		},
		"/auth/register": {
			"post": {
				"operationId": "Register",
				"responses": {
					"200": {
						"description": "Registration successful",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/DTOLoginResponse"
								}
							}
						}
					},
					"400": {
						"description": "Invalid registration payload"
					},
					"409": {
						"description": "Username or email already exists"
					}
				},
				"tags": [
					"Auth"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/RegisterRequest"
							}
						}
					}
				}
			}
		},
		"/auth/users/{userId}": {
			"get": {
				"operationId": "GetUser",
				"responses": {
					"200": {
						"description": "User found",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/DTOUser"
								}
							}
						}
					},
					"404": {
						"description": "User not found"
					}
				},
				"tags": [
					"Auth"
				],
				"security": [],
				"parameters": [
					{
						"in": "path",
						"name": "userId",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				]
			}
		}
	},
	"servers": [
		{
			"url": "/api"
		}
	]
}