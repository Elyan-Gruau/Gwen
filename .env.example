# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=3600  # Token expiration in seconds (3600 = 1 hour)

# MongoDB Configuration
MONGODB_URI=mongodb://gwen_user:gwen_password@localhost:27017/gwen?authSource=admin

# Docker Compose Mongo root user (used by mongo service)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin_password
MONGO_INITDB_DATABASE=gwen

# Client Configuration
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
